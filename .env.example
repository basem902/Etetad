# =============================================
# .env.example — قالب متغيرات البيئة (RC 1.0.0)
# =============================================
# انسخ هذا الملف إلى .env.local وعبّئ القيم.
# .env.local مُتجاهَل في git — لا يُلتزَم أبداً.
#
# Production: اضبط نفس المتغيرات في Vercel Project Settings → Environment Variables.
# =============================================

# --- Supabase (إلزامي) ---
# مصدر القيم: Supabase Dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL
#   عنوان مشروع Supabase. مثال: https://abcdefgh.supabase.co
#   آمن للعرض في الـ client (URL وحده ليس سراً).
NEXT_PUBLIC_SUPABASE_URL=

# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   المفتاح العام (anon). يُستخدم من المتصفح للـ auth/RLS.
#   آمن للعرض في الـ client — RLS تَحميه.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY
#   مفتاح service_role. يَتجاوز RLS — server-side فقط.
#   ⚠️ سرّي تماماً. لا يَظهر في الـ client. لا يُلتزَم في git.
#
#   مَواضع الاستخدام في المشروع (كلها server-only، scope ضيق):
#
#   1. src/lib/supabase/auth-admin.ts → getAuthAdmin()
#      wrapper مُتعمَّد يَكشف ONLY الـ auth.admin API surface (لا from() ولا
#      rpc() ولا storage). يُستخدم في linkOrInviteMemberAction (Phase 5+) و
#      addTeamMemberAction (Phase 19) لـ auth.admin.listUsers + inviteUserByEmail.
#
#   2. src/lib/supabase/admin.ts → createAdminClient() (Phase 16+)
#      يُستدعى من server actions/routes لـ RPC narrow scope:
#        - submit_contact_request (Phase 16) — choke point للـ /contact
#        - log_email_failure       — audit_logs writes (server-only، لمنع spam)
#        - create_subscription_order (Phase 18) — anon-server bridge للـ /subscribe
#        - expire_due_subscriptions (Phase 18) — daily cron
#        - subscription_receipts upload (Phase 18 API route)
#        - bulk_import_uploads (Phase 19 admin API)
#        - find_and_record_subscription_reminders (Phase 19) — daily cron
#      الـ admin client لا يَلمس tables تَطبيقية مُباشرةً — كل الكتابات عبر
#      SECURITY DEFINER RPCs تَفرض القيود داخلياً (lessons #28، #31).
#
#   ⚠️ إن لم تَضبط هذا المفتاح:
#     - نموذج /contact يَفشل بـ "الخدمة غير مُكوَّنة"
#     - /subscribe (طلب اشتراك جديد) يَفشل
#     - رَفع إيصال التَحويل يَفشل
#     - cron endpoints الثلاثة تُرجع 503
#     - "ربط/دعوة عضو" من admin يَفشل
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (إلزامي) ---
# NEXT_PUBLIC_APP_URL
#   العنوان العام للتطبيق. يُستخدم في:
#   - رسائل reset-password (rebuild الرابط)
#   - PWA manifest و share targets
#   - canonical URLs
#   - /subscribe receipt URLs (Phase 18)
#   - reminder emails CTA (Phase 19)
#
#   Local:      http://localhost:3000
#   Production: https://your-domain.com  (بدون / في النهاية)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email — Resend (إلزامي للـ production) ---
# ⚠️ نِطاق Resend هنا = **بريد التطبيق فقط** (transactional emails من
# `src/lib/email/index.ts`). رسائل **Supabase Auth** (Confirm signup،
# Reset password، `auth.admin.inviteUserByEmail`) تُرسَل عبر مَزود Supabase
# الافتراضي — مُنفصل تماماً، لا علاقة له بـ Resend. لو أردت تَخصيص
# مَزود Auth (مثلاً Resend عبر custom SMTP)، اضبطه من Supabase Dashboard
# → Authentication → SMTP Settings (راجع DEPLOYMENT §2.4).
#
# مصدر القيم: https://resend.com/api-keys
#
# RESEND_API_KEY
#   مفتاح Resend API. server-only، لا يُحقَن في الـ bundle.
#   يُستخدم في `src/lib/email/index.ts` → sendEmail() لإرسال:
#     - /contact confirmation + super_admin notification (Phase 16)
#     - /subscribe order created/approved/rejected (Phase 18)
#     - renewal created/approved (Phase 19)
#     - subscription reminders 30/14/7 يوماً (Phase 19)
#
#   فشل الإرسال يُسجَّل في طَبقتَين مُختلفَتَين بحَسب نوع البريد:
#     - app emails أعلاه → `log_email_failure` RPC → جدول `audit_logs`
#       (entity_type='subscription_order'|'contact_request'|...)
#     - subscription_reminders فقط → `update_reminder_email_status` RPC →
#       جدول `subscription_reminders_sent.email_status` ('queued'|'sent'|'failed')
#       + `email_error` (لا تُكتب في audit_logs لأن idempotency tracker
#       منفصل، ولأن super_admin يُراقبها من /super-admin مع reminder rows)
#
#   ⚠️ في production بدون هذا المفتاح: التطبيق يَعمل (DB integrity مَحفوظة)،
#   لكن العميل لا يَستلم تَعليمات/تأكيد. invites Supabase Auth **غير
#   مُتأثِّرة** بهذا — تَستمر عبر مَزود Supabase.
#
#   Development: اتركه فارغاً — emails تَطبع في console فقط (graceful skip).
RESEND_API_KEY=

# RESEND_FROM_EMAIL
#   عنوان "From" لرسائل التطبيق فقط. يَجب أن يَكون verified في Resend
#   dashboard. مثال: noreply@your-domain.com
#
#   Resend يَرفض الإرسال من domain غير verified.
#   لا علاقة بـ "From" رسائل Supabase Auth — تلك تَستخدم القيمة المَضبوطة
#   في Supabase Dashboard → Authentication → Email Templates.
#
#   Development: اتركه فارغاً — يُتجاهَل مع graceful skip.
RESEND_FROM_EMAIL=

# --- Cron (إلزامي للـ production) ---
# CRON_SECRET
#   string عشوائي (32+ char) يَحمي endpoints الـ cron من unauthorized access.
#   Vercel Cron يُرسل `Authorization: Bearer ${CRON_SECRET}` تلقائياً.
#
#   مَواضع الاستخدام (3 cron routes في vercel.json):
#     - /api/cron/expire-orders          (يَومي 02:00 UTC) — abandoned subscription_orders > 30 يوم
#     - /api/cron/expire-subscriptions   (يَومي 02:05 UTC) — buildings with subscription_ends_at < now
#     - /api/cron/subscription-reminders (يَومي 09:00 UTC) — 30/14/7 day notifications
#
#   كل route بدون الـ header الصحيح يُرجع 401.
#   بدون هذا المتغير، الـ routes تُرجع 503 ("CRON_SECRET not configured").
#
#   لتَوليد القيمة:
#     openssl rand -base64 32
#   أو من https://generate-secret.vercel.app/32
#
#   ⚠️ سرّي. لا يُحقَن في الـ client. لا يُلتزَم في git.
CRON_SECRET=

# --- Notifications (اختياري لكن موصى به للـ production) ---
# SUPER_ADMIN_NOTIFICATION_EMAIL
#   البريد الذي يَستلم إشعارات /contact form (Phase 16). لو فارغ، الإشعار
#   يُتجاهَل بصمت (الطلب يُسجَّل في DB بشكل عادي).
#
#   مَوضع الاستخدام: src/actions/marketing.ts → submitContactRequestAction
#
#   عادةً: نَفس بريد المالك/super_admin.
SUPER_ADMIN_NOTIFICATION_EMAIL=

# =============================================
# ملاحظات
# =============================================
# - أي متغير يَبدأ بـ NEXT_PUBLIC_ يُحقَن في bundle المتصفح. لا تَضع فيه أسراراً.
# - بعد تغيير أي متغير محلياً، أعد تشغيل dev server.
# - في Vercel، إعادة الـ deploy ضروري بعد تعديل المتغيرات.
# - متغيرات إلزامية لتَشغيل full production: 7 (Supabase×3 + APP_URL + Resend×2 + Cron).
# - متغير اختياري: 1 (SUPER_ADMIN_NOTIFICATION_EMAIL).
# - Development: يَكفي 4 (Supabase×3 + APP_URL). الباقي يَتعطَّل بأمان.
